<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project Camp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="/stylesheets/home.css">
</head>

<body class="d-flex  text-center text-white bg-dark">

    <div class="cover-container d-flex w-100 h-100 p-3 mx-auto flex-column">
        <header class="mb-auto">
            <div class="d-flex justify-content-between align-items-center">

                <h3 class="mb-0"> <a class="ProjectHead" href="/">Project Camp </a></h3>

                <nav class="nav nav-masthead">

                    <a class="nav-link  active" aria-current="page" href="/campgrounds">Campgrounds</a>

                    <% if (!currentUser) { %>
                        <a class="nav-link" href="/login">Login</a>
                        <a class="nav-link" href="/register">Register</a>


                        <% }else{ %>
                            <span class="navbar-text me-2">Hello, <%=currentUser.username %>!</span>
                            <a class="nav-link" href="/logout">Logout</a>

                            <% } %>


                </nav>
            </div>
        </header>
        <main class="px-3">
            <h1>Project Camp</h1>
            <p>Welcome to Your Campground, a place where adventure begins and memories are made. Discover unique camping
                spots shared by travelers from around the world, each with real reviews, beautiful locations, and
                everything you need to plan your next outdoor escape. Whether you're looking for a peaceful retreat in
                nature or an exciting new destination to explore, you’ll find the perfect spot here. Start your journey,
                share your experiences, and connect with a community that loves the outdoors as much as you do.
            </p>
            <a href="/campgrounds" class="btn btn-secondary fw-bold bg-white">View Campgrounds </a>

        </main>

        <footer class="mt-auto text-white-50">
            <p>&copy; 2026 Project Camp</p>
        </footer>
    </div>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>